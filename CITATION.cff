    affiliation: "Speech and Text Computing Group, Department of Linguistics and Philology, Addis Ababa University"
version: 0.1.0
date-released: 2024-07-11
license: "MIT"
repository-code: "https://github.com/fedanegesse-blip/qubee-ipa-converter"
url: "https://github.com/fedanegesse-blip/qubee-ipa-converter"
keywords:
